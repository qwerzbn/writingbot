{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/co-writer/layout,_N_T_/co-writer/page,_N_T_/co-writer"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/co-writer/__PAGE__",
    "/co-writer",
    "/_index",
    "/_head"
  ]
}