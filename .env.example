# ==============================================================================
# WritingBot Environment Configuration
# ==============================================================================
# Copy this file to `.env` and fill in the values.

# ==============================================================================
# LLM Configuration (For Answer Generation)
# ==============================================================================

# Provider: "openai", "ollama", or any OpenAI-compatible API
LLM_PROVIDER=openai

# --- Recommended: Alibaba Cloud Bailian / DashScope (OpenAI-compatible, multimodal) ---
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.6-plus
LLM_API_KEY=your_dashscope_api_key_here
# Aliases also supported for manual env setup: BASE_URL / MODEL_ID / API_KEY

# --- Option 2: Ollama (Local) ---
# Make sure Ollama is running: `ollama serve`
# List models: `ollama list`
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen3:0.6b
# LLM_API_KEY=ollama

# --- Option 3: OpenAI API ---
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-xxx

# --- Option 4: DeepSeek API ---
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-xxx

# Tip: chart understanding uses the same OpenAI-compatible model entry above.
# qwen3.6-plus can accept text + image inputs for chart understanding demos.

# ==============================================================================
# Note: Embedding Configuration
# ==============================================================================
# Embedding models are configured PER KNOWLEDGE BASE when you create them.
# You can choose from:
#   - Local (HuggingFace): all-mpnet-base-v2, all-MiniLM-L6-v2
#   - Ollama (Local): nomic-embed-text (requires Ollama running)
#   - OpenAI (API): text-embedding-3-small, text-embedding-3-large
#
# This allows different knowledge bases to use different embedding models.

# ==============================================================================
# Debug & Development
# ==============================================================================

# Frontend proxy target (web /api -> backend)
WRITINGBOT_API_URL=http://127.0.0.1:5001

# FastWrite base URLs used by backend bridge and frontend co-writer
FASTWRITE_URL=http://127.0.0.1:3002
NEXT_PUBLIC_FASTWRITE_URL=http://127.0.0.1:3002

# Set to "true" to see detailed logs
DEBUG=false
